{
  "name": "github-analytics",
  "version": "1.0.0",
  "description": "GitHub Analytics - GitHub活動分析ツール",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "lint:markdown": "markdownlint-cli2 '**/*.md' '!**/node_modules/**' '!vendor/**' '!output/**'",
    "lint:markdown:fix": "markdownlint-cli2-fix '**/*.md' '!**/node_modules/**' '!vendor/**' '!output/**'",
    "lint:json": "prettier --check '**/*.json' '!**/node_modules/**' '!vendor/**' '!output/**' '!**/pnpm-lock.yaml'",
    "lint:yaml": "prettier --check '**/*.{yaml,yml}' '!**/node_modules/**' '!vendor/**' '!output/**' '!**/pnpm-lock.yaml'",
    "lint:json-yaml": "pnpm run lint:json && pnpm run lint:yaml",
    "format:json": "prettier --write '**/*.json' '!**/node_modules/**' '!vendor/**' '!output/**' '!**/pnpm-lock.yaml'",
    "format:yaml": "prettier --write '**/*.{yaml,yml}' '!**/node_modules/**' '!vendor/**' '!output/**' '!**/pnpm-lock.yaml'",
    "format:json-yaml": "pnpm run format:json && pnpm run format:yaml"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.14.0",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
